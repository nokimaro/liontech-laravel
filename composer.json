{
    "name": "nokimaro/liontech-laravel",
    "description": "Laravel package for LionTech Payment Gateway SDK",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "liontech",
        "payment",
        "payment-gateway",
        "sdk",
        "laravel-package"
    ],
    "homepage": "https://github.com/nokimaro/liontech-laravel",
    "support": {
        "issues": "https://github.com/nokimaro/liontech-laravel/issues",
        "source": "https://github.com/nokimaro/liontech-laravel"
    },
    "authors": [
        {
            "name": "Nik Dm",
            "email": "nox@nox.kz",
            "role": "Maintainer"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "nokimaro/liontech-php-sdk": "^1.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.5",
        "phpstan/phpstan": "^2.0",
        "symplify/easy-coding-standard": "^12.3 || ^13.0",
        "rector/rector": "^2.0",
        "pestphp/pest-plugin-type-coverage": "^3.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "psr/log": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Nokimaro\\LionTech\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nokimaro\\LionTech\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nokimaro\\LionTech\\Laravel\\LionTechServiceProvider"
            ],
            "aliases": {
                "LionTech": "Nokimaro\\LionTech\\Laravel\\Facades\\LionTech"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "optimize-autoloader": true,
        "preferred-install": "dist"
    },
    "scripts": {
        "test": "vendor/bin/pest --compact",
        "test-coverage": "XDEBUG_MODE=\"coverage\" vendor/bin/pest --coverage --min=100",
        "test-type-coverage": "vendor/bin/pest --type-coverage --min=100",
        "phpstan": "vendor/bin/phpstan analyse",
        "ecs": "vendor/bin/ecs check",
        "ecs-fix": "vendor/bin/ecs check --fix",
        "rector": "vendor/bin/rector process",
        "rector-check": "vendor/bin/rector process --dry-run",
        "check": [
            "@ecs",
            "@phpstan",
            "@rector-check",
            "@test",
            "@test-coverage",
            "@test-type-coverage"
        ],
        "fix": [
            "@ecs-fix",
            "@rector"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
